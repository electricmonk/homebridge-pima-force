{
  "name": "homebridge-pima-force",
  "displayName": "Pima FORCE",
  "version": "0.1.13",
  "description": "Homebridge plugin for the Pima FORCE alarm panel via local CMS protocol over TCP/JSON",
  "type": "module",
  "author": {
    "name": "Shai Yallin",
    "email": "shai.yallin@gmail.com",
    "url": "https://github.com/electricmonk"
  },
  "homepage": "https://github.com/electricmonk/homebridge-pima-force",
  "bugs": {
    "url": "https://github.com/electricmonk/homebridge-pima-force/issues"
  },
  "contributors": [
    {
      "name": "Claude Code",
      "url": "https://claude.ai"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electricmonk/homebridge-pima-force.git"
  },
  "license": "LGPL-3.0-or-later",
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "version": "conventional-changelog -p conventionalcommits && git add CHANGELOG.md",
    "cli": "tsx src/cli.ts",
    "hb:dev:link": "ln -sfn .. node_modules/homebridge-pima-force",
    "hb:dev": "npm run hb:dev:link && npm run build && npx hb-service run -U ./hb-dev -P .",
    "test": "npm run hb:dev:link && npm run build && node --import tsx --test src/*.test.ts",
    "test:unit": "node --import tsx --test src/protocol.test.ts",
    "test:integration": "node --import tsx --test src/driver.test.ts",
    "test:e2e": "npm run hb:dev:link && npm run build && node --import tsx --test src/e2e.test.ts",
    "test:e2e:hb2": "npm install homebridge@^2.0.0 --no-save --legacy-peer-deps && npm run test:e2e",
    "test:e2e:all-hb": "bash scripts/e2e-hb-versions.sh"
  },
  "keywords": [
    "homebridge-plugin",
    "pima",
    "pima-force",
    "alarm"
  ],
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0",
    "node": ">=22"
  },
  "peerDependencies": {
    "homebridge": "^1.6.0 || ^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "homebridge": "^1.8.0",
    "homebridge-config-ui-x": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
